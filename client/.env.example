# FlowLens frontend — copy to .env for local dev; for Vercel set these in Project Settings → Environment Variables
# Required for deployment (no default in production build):
#   VITE_API_URL     — backend URL (e.g. https://flowlens-api.onrender.com)
#   VITE_ANALYTICS_URL — analytics URL (e.g. https://flowlens-analytics.onrender.com)
# Local dev (optional; used when not set):
VITE_API_URL=http://localhost:4000
VITE_ANALYTICS_URL=http://localhost:8000
