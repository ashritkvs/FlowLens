# FlowLens — env vars for docker-compose (optional)
# Copy to .env in project root if you use docker compose and want to override defaults.

# Frontend origin (for server CORS). Used when running backend in Docker and frontend on host.
CLIENT_ORIGIN=http://localhost:5173

# Analytics CORS: * or comma-separated origins
CORS_ORIGINS=*

# Only needed when building frontend in Docker with production API URLs
# VITE_API_URL=https://your-api.onrender.com
# VITE_ANALYTICS_URL=https://your-analytics.onrender.com
