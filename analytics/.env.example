# FlowLens Analytics (FastAPI)
# Copy to .env and set for local or production (Render/Railway).

# MongoDB: local Docker or Atlas connection string (no DB name in URI for Atlas)
MONGODB_URI=mongodb://localhost:27017/
DB_NAME=flowlens

# Comma-separated list of allowed origins for CORS, or * for all (dev)
# Example: https://your-app.vercel.app,https://www.your-app.vercel.app
CORS_ORIGINS=*
