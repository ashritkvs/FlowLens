# FlowLens Analytics (FastAPI) — copy to .env; for Render set in Dashboard → Environment
# Required for deployment:
#   MONGODB_URI  — Atlas URI without DB path (e.g. mongodb+srv://user:pass@cluster.mongodb.net/)
#   DB_NAME      — flowlens
#   CORS_ORIGINS — deployed frontend URL for CORS (e.g. https://flowlens.vercel.app) or * for dev
#   PORT         — set by Render (or 8000)
MONGODB_URI=mongodb://localhost:27017/
DB_NAME=flowlens
CORS_ORIGINS=*
PORT=8000
