# FlowLens Express API — copy to .env; for Render set in Dashboard → Environment
# Required for deployment:
#   PORT            — set by Render (or 4000)
#   MONGODB_URI     — Atlas connection string including DB (e.g. mongodb+srv://user:pass@cluster.mongodb.net/flowlens?retryWrites=true&w=majority)
#   CLIENT_ORIGIN   — deployed frontend URL for CORS (e.g. https://flowlens.vercel.app)
PORT=4000
MONGODB_URI=mongodb://localhost:27017/flowlens
CLIENT_ORIGIN=http://localhost:5173
